# ==============================================================================
#          💸 AI FINANCIAL ANALYST CREW - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to '.env' and fill in your credentials to run the application.

# ------------------------------------------------------------------------------
# 🧠 CORE AI ENGINE (Required)
# ------------------------------------------------------------------------------
# Your OpenAI API key to power the CrewAI agents (Quantitative, Risk, Strategist, Publisher).
# Recommends GPT-4o or GPT-4o-mini.
OPENAI_API_KEY="your-openai-api-key-here"

# ------------------------------------------------------------------------------
# 🔍 LIVE WEB SEARCH & RESEARCH (Required)
# ------------------------------------------------------------------------------
# Firecrawl key is used to search the web for recent news, crawl articles, and perform 
# live semantic search on analyst ratings. Get a key at: https://www.firecrawl.dev
FIRECRAWL_API_KEY="your-firecrawl-api-key-here"

# ------------------------------------------------------------------------------
# 📊 MACROECONOMIC ECONOMIC DATA (Required)
# ------------------------------------------------------------------------------
# Federal Reserve Economic Data (FRED) API key. Used to fetch CPI, Inflation, GDP growth, 
# and Interest Rates for both US and Indian stock contexts.
# Get a FREE API key instantly at: https://fred.stlouisfed.org/api/keys.html
FRED_API_KEY="your-fred-api-key-here"

# ------------------------------------------------------------------------------
# ☁️ AZURE CLOUD PERSISTENCE (Optional)
# ------------------------------------------------------------------------------
# If left blank, the application will skip cloud persistence and save reports 
# locally as markdown files without throwing errors.

# 🗄️ Azure PostgreSQL Connection String (Stores report metadata and history)
# Format: postgresql://<username>:<password>@<host>:5432/<database>?sslmode=require
AZURE_POSTGRES_CONNECTION_STRING=""

# 📦 Azure Blob Storage Connection String (Stores final Markdown files permanently)
# Format: DefaultEndpointsProtocol=https;AccountName=<name>;AccountKey=<key>;EndpointSuffix=core.windows.net
AZURE_BLOB_STORAGE_CONNECTION_STRING=""

# ------------------------------------------------------------------------------
# 🔬 OBSERVABILITY & AGENT TRACING (Optional)
# ------------------------------------------------------------------------------
# LangSmith integration logs every single step, token, and prompt used by the agents.
# Set to 'true' and provide a key to enable detailed agent telemetry.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=""
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_PROJECT="multiagent_azure_crewai"
